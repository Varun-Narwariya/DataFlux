# .env
# Copy this to .env and fill in values
# Never commit .env to git

NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/datafluxai

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/datafluxai?authSource=admin
MONGODB_DB=datafluxai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage ───────────────────────────────────────────────────────────────────
# Change to 'aws' or 'r2' for production
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
BUCKET_UPLOADS=datafluxai-uploads
BUCKET_OUTPUTS=datafluxai-outputs

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── AWS (fill these in when you get to Step 4) ────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Lambda function names (fill after deploying) ──────────────────────────────
# LAMBDA_IMAGE_TO_PDF=datafluxai-image-to-pdf
# LAMBDA_PDF_MERGE=datafluxai-pdf-merge
# LAMBDA_PDF_SPLIT=datafluxai-pdf-split
# LAMBDA_EXIF=datafluxai-exif

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# LITELLM_BASE_URL=http://localhost:4000
# LITELLM_API_KEY=sk-dev
# OPENAI_API_KEY=sk-...
